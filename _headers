/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

/assets/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS hebben geen hash in de bestandsnaam; laat de browser ze hervalideren
# (ETag → 304 als ongewijzigd) zodat stijl/JS-wijzigingen na een gewone reload
# zichtbaar worden i.p.v. een jaar lang vast te staan.
/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate
/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

# Admin-pagina's wijzigen regelmatig: nooit cachen, anders draait de browser
# op een verouderde admin.html (bv. oude mailteksten / formuliervelden).
/admin
  Cache-Control: no-store
/admin.html
  Cache-Control: no-store
/admin-wachtwoord
  Cache-Control: no-store
/admin-wachtwoord.html
  Cache-Control: no-store
